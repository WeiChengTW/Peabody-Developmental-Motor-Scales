# ========== 基本忽略 ==========
PDMS2_web/console.txt
*.pyc
__pycache__/

# ========== 追蹤特定的圖片資料夾 (保留 HEAD 的意圖) ==========
!PDMS2_web/images/
!PDMS2_web/images/*.jpg
!PDMS2_web/images/*.png

# ========== 核心忽略 (解決 Push 失敗的問題) ==========
# 不要把模型檔 (.h5) 放進 Git
*.h5
PDMS2_web/ch2-t1/model/
PDMS2_web/ch2-t2/model/
PDMS2_web/ch2-t3/model/

# 忽略大型影片檔，避免推送到雲端時卡住
*.mp4
PDMS2_web/video/
PDMS2_web/recordings/

# 忽略受測者隱私資料
PDMS2_web/kid/
PDMS2_web/result/

# 忽略本地測試腳本
PDMS2_web/run_user.py